# Barangay Sentinel — Environment Variables
# Copy this file to .env and fill in the values.

# REQUIRED: A random secret key for Flask session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Optional: Set to 'true' only during local development.
FLASK_DEBUG=false

# Optional: PostgreSQL connection string.
# If not set, falls back to SQLite (instance/sentinel_users.db).
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/sentinel_db

# --- SMTP — Password Recovery Emails ---
# Required for the "Forgot Access Code?" flow.
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=pakuallzxg@gmail.com
SMTP_PASSWORD=fvha fxlq okgc wxfe
MAIL_FROM_NAME=Barangay Sentinel

# --- Password Reset Tuning (optional) ---
PASSWORD_RESET_TTL_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
